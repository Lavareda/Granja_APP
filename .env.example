# =============================================================================
# GranjaApp — Environment Variables
#
# Copy this file to .env and fill in your Supabase project values.
# The .env file is in .gitignore and must NEVER be committed to Git.
#
# SECURITY:
#   ▸ Use ONLY the anon/public key here — never the service_role key.
#   ▸ The anon key is safe to expose in frontend code because
#     Row Level Security (RLS) prevents cross-user data access.
#   ▸ The service_role key bypasses RLS and must stay server-side only.
#
# Where to find these values:
#   Supabase Dashboard → Project Settings → API → Project URL / Project API keys
# =============================================================================

# Your Supabase project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public key (safe for frontend)
# ⚠  Do NOT use the service_role key here
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Optional: leave both variables empty (or delete them) to run in demo mode.
# Demo mode uses localStorage with pre-loaded sample data and requires no login.
# =============================================================================
